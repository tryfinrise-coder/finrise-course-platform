# ---- Finrise environment ----
# Copy to .env.local and fill in real values. Never commit .env.local.

# Secret used to sign the session JWT (httpOnly cookie). Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-string

# Default admin account, created automatically on first run if it does not exist.
ADMIN_EMAIL=admin@tryfinrise.com
ADMIN_PASSWORD=change-me-admin-password

# ---- MySQL database ----
# Either set a single URL, OR the discrete vars below (URL wins if both are set).
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/finnora
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=finnora

# ---- Subdomains ----
# In production, scope the login cookie to the apex so it spans
# admin./courses./www. Leave unset for local dev (admin.localhost etc.).
# COOKIE_DOMAIN=.tryfinrise.com

# ---- Razorpay (Phase 2) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ---- SMTP email (Phase 2: emailing login credentials) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Finrise <no-reply@tryfinrise.com>"

# ---- Brevo email (Phase 2: preferred over SMTP) ----
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@tryfinrise.com
BREVO_SENDER_NAME="Finrise"

# Public base URL of the app (used in emails / Razorpay callbacks)
APP_URL=http://localhost:3000
